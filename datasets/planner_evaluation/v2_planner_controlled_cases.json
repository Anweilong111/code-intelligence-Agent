      "expected_classification": {"rule": "none", "llm": "network", "hybrid": "network"}
    },
    {
      "name": "action_budget_exhausted",
      "summary_mode": "budget_exhausted",
      "proposal": {"selected_action": "generate_hybrid_patch_candidates", "arguments": {}, "confidence": 0.9},
