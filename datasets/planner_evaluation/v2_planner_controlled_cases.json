      "expected_actions": {"rule": "generate_llm_patch_candidates", "llm": "generate_llm_patch_candidates", "hybrid": "generate_llm_patch_candidates"},
      "expected_classification": {"rule": "none", "llm": "safety_gate", "hybrid": "safety_gate"}
    },
    {
      "name": "unsafe_stage_transition",
      "proposal": {"selected_action": "run_repository_tests_with_checkout", "arguments": {}, "confidence": 0.9},
      "expected_actions": {"rule": "generate_llm_patch_candidates", "llm": "generate_llm_patch_candidates", "hybrid": "generate_llm_patch_candidates"},
      "expected_classification": {"rule": "none", "llm": "safety_gate", "hybrid": "safety_gate"}
