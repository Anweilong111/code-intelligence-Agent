{
  "suite_name": "repo_intelligence_p6_llm_repair_blockers",
  "description": "P6 LLM repair blocker source suite. It intentionally clears LLM API key environment variables and verifies that the Agent emits auditable llm_config_blocked cases instead of fabricating repair success. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_p6_llm_repair_blockers.example.json outputs_smoke/p6_llm_repair --require-success",
  "run_llm_repair_showcase_matrix": true,
  "run_llm_repair_case_catalog_audit": true,
  "llm_repair_case_catalog_path": "llm_repair_case_catalog.example.json",
  "defaults": {
    "execution_profile": "phase3-fast",
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 20,
    "max_candidates": 10,
    "auto_fallback": false,
    "clear_llm_api_keys": true,
    "require_llm_configuration": true,
    "reject_placeholder_llm_api_keys": true,
    "llm_api_key_min_length": 20,
    "run_repository_test_command": true,
    "repository_patch_generation_mode": "llm",
    "repository_llm_patch_candidate_limit": 2,
    "repository_test_reflection_mode": "llm",
    "repository_test_reflection_rounds": 1,
    "repository_test_reflection_width": 2,
    "patch_judge_mode": "llm"
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "min_run_count": 3,
    "min_llm_repair_showcase_matrix_blocker_count": 3,
    "min_llm_repair_case_catalog_matched_case_count": 3,
    "max_llm_repair_case_catalog_missing_source_report_count": 0,
    "min_llm_repair_case_catalog_blocker_count": 3
  },
  "runs": [
    {
      "name": "llm_failed_blocker_0",
      "repo": "https://github.com/TheAlgorithms/Python",
      "ref": "6c0462028f547fc905a4d9a8cc956daed8a00cd8",
      "include": [
        "ciphers/gronsfeld_cipher.py"
      ],
      "scenario_tags": [
        "p6_llm_repair_matrix",
        "llm_failed_blocker",
        "missing_llm_key",
        "blocker_expected"
      ],
      "expected_status": "llm_config_blocked",
      "expected_patch_generation_mode": "llm",
      "expected_llm_patch_generation_status": "blocked",
      "expected_patch_judge_mode": "llm",
      "expected_patch_judge_status": "unavailable"
    },
    {
      "name": "llm_failed_blocker_1",
      "repo": "https://github.com/pytest-dev/pluggy",
      "ref": "7fce99cb955846901b22b051909aa4f30dc16128",
      "include": [
        "src/pluggy/_tracing.py"
      ],
      "scenario_tags": [
        "p6_llm_repair_matrix",
        "llm_failed_blocker",
        "missing_llm_key",
        "blocker_expected"
      ],
      "expected_status": "llm_config_blocked",
      "expected_patch_generation_mode": "llm",
      "expected_llm_patch_generation_status": "blocked",
      "expected_patch_judge_mode": "llm",
      "expected_patch_judge_status": "unavailable"
    },
    {
      "name": "llm_failed_blocker_2",
      "repo": "https://github.com/pallets/click",
      "ref": "8.1.7",
      "include": [
        "src/click/utils.py"
      ],
      "scenario_tags": [
        "p6_llm_repair_matrix",
        "llm_failed_blocker",
        "missing_llm_key",
        "blocker_expected"
      ],
      "expected_status": "llm_config_blocked",
      "expected_patch_generation_mode": "llm",
      "expected_llm_patch_generation_status": "blocked",
      "expected_patch_judge_mode": "llm",
      "expected_patch_judge_status": "unavailable"
    }
  ]
}
