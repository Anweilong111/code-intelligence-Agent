{
  "suite_name": "repo_intelligence_p6_onboarding_readiness",
  "description": "P6 onboarding readiness suite for the public Python GitHub repository intelligence Agent. It prepares a 10-repository matrix for real repository onboarding, AgentController trace auditing, onboarding matrix generation, and P6 readiness reporting. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_p6_onboarding_readiness.example.json outputs_smoke/repo_intelligence_p6_onboarding_readiness_current --require-success",
  "run_github_onboarding_matrix": true,
  "run_llm_repair_showcase_matrix": true,
  "run_llm_repair_case_catalog_audit": true,
  "run_p6_readiness_audit": true,
  "llm_repair_case_catalog_path": "llm_repair_case_catalog.example.json",
  "llm_repair_source_reports": [
    "../../outputs_smoke/p6_llm_repair/github_repo_intelligence_suite.json"
  ],
  "github_onboarding_matrix_required_case_count": 10,
  "defaults": {
    "execution_profile": "agent-auto",
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 30,
    "max_candidates": 10,
    "auto_fallback": false,
    "run_repository_test_command": false,
    "repository_patch_generation_mode": "rule",
    "repository_test_timeout": 20,
    "repository_checkout_timeout": 120,
    "repository_checkout_depth": 1,
    "auto_controller_max_actions": 0
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "max_scenario_coverage_blocked_count": 0,
    "max_objective_compliance_failed_section_kind_count": 0,
    "max_blocked_agent_answer_incomplete_count": 0,
    "min_run_count": 10,
    "min_agent_shortcut_count": 2,
    "min_repo_input_kind_count": 2,
    "min_repo_input_kind_owner_repo_count": 1,
    "min_repo_input_kind_github_url_count": 9,
    "min_scenario_tag_kind_count": 25,
    "min_scenario_tag_p6_onboarding_readiness_count": 10,
    "min_scenario_tag_pytest_project_count": 1,
