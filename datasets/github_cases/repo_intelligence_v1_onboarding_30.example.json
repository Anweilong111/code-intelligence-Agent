{
  "suite_name": "repo_intelligence_v1_onboarding_30",
  "description": "V1 target manifest for 30 public GitHub repository onboarding cases. This is the target set for arbitrary-repo Agent evaluation; run it with github_repo_intelligence_suite to generate evidence reports before claiming v1 completion.",
  "v1_target": {
    "onboarding_case_count": 30,
    "agent_loop": "Observe -> Plan -> Act -> Verify -> Reflect -> Replan"
  },
  "defaults": {
    "execution_profile": "agent-auto",
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 20,
    "max_candidates": 10,
    "auto_fallback": true,
    "run_repository_test_command": false,
    "checkout_repository_tests": false,
    "repository_patch_generation_mode": "rule",
    "repository_test_timeout": 20,
    "repository_checkout_timeout": 120,
    "repository_checkout_depth": 1,
    "auto_controller_max_actions": 0
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "min_run_count": 30,
    "min_scenario_tag_v1_onboarding_count": 30,
    "min_scenario_tag_kind_count": 13,
    "min_agent_controller_loop_complete_count": 30,
    "min_agent_decision_timeline_complete_count": 30,
    "min_artifact_core_ready_count": 30,
    "min_objective_compliance_pass_count": 30
  },
  "runs": [
    {
      "name": "pypa_sampleproject_v1_owner_repo",
