{
  "suite_name": "v2_unfamiliar_python_repositories_20",
  "description": "Phase 6 holdout suite for 20 public Python repositories that were not referenced by the implementation or earlier repository manifests when selected. Every run is pinned to a 40-character commit SHA.",
  "selection_policy": {
    "selected_at": "2026-07-14",
    "role": "unfamiliar_holdout",
    "minimum_case_count": 20,
    "fixed_commit_required": true,
    "development_reference_scan": "No exact owner/repository reference existed in tracked source, tests, docs, or datasets at selection time.",
    "coverage_targets": [
      "small_library",
      "cli",
      "web",
      "data_processing",
      "src_layout",
      "flat_layout",
      "multi_package",
      "native_extension",
      "tox_or_nox",
      "modern_pyproject"
    ]
  },
  "defaults": {
    "execution_profile": "agent-auto",
    "preset": "mining",
    "source_cache_dir": "outputs_v2/phase6/source_cache",
    "max_sources": 12,
    "max_candidates": 5,
    "auto_fallback": false,
    "run_repository_test_command": true,
    "run_repository_test_environment_setup": false,
    "run_repository_test_retry": false,
    "auto_repository_test_retry": false,
    "repository_patch_generation_mode": "rule",
    "repository_test_reflection_mode": "none",
    "repository_test_timeout": 8,
    "repository_checkout_timeout": 90,
    "repository_checkout_depth": 1,
    "auto_controller_max_actions": 0,
    "clear_llm_api_keys": true
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "min_run_count": 20
  },
