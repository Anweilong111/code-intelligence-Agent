{
  "suite_name": "repo_intelligence_agent_cli_default_output_blocker_matrix",
  "description": "Repo-only CLI default-output blocker matrix for arbitrary public Python repositories. Every run uses agent=true and use_cli_default_output_dir=true, so github_repo_intelligence is invoked without an output_dir positional argument while validating that test-environment blockers and no-test-command blockers still produce auditable Agent answers and next actions. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_agent_cli_default_output_blocker_matrix.example.json outputs_smoke/repo_intelligence_agent_cli_default_output_blocker_matrix_current --require-success",
  "defaults": {
    "agent": true,
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 30,
    "max_candidates": 10,
    "auto_fallback": true,
    "run_repository_test_command": true,
    "repository_patch_generation_mode": "rule",
    "repository_test_timeout": 20,
    "repository_checkout_timeout": 120,
    "repository_checkout_depth": 1,
    "auto_controller_max_actions": 4,
    "use_cli_default_output_dir": true
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "max_existing_report_reuse_count": 0,
    "max_cached_report_fallback_count": 0,
    "max_discovery_cache_fallback_count": 0,
    "max_scenario_coverage_blocked_count": 0,
    "min_run_count": 2,
    "min_agent_shortcut_count": 2,
    "min_output_dir_defaulted_count": 2,
    "min_agent_default_output_dir_count": 2,
    "min_repo_input_kind_count": 2,
    "min_repo_input_kind_owner_repo_count": 1,
    "min_repo_input_kind_github_url_count": 1,
    "min_scenario_tag_cli_default_output_count": 2,
    "min_scenario_tag_owner_repo_input_count": 1,
    "min_scenario_tag_github_url_input_count": 1,
    "min_scenario_tag_default_branch_discovery_count": 2,
    "min_scenario_tag_source_cache_count": 2,
    "min_scenario_tag_checkout_tests_count": 2,
    "min_scenario_tag_test_environment_blocker_count": 1,
    "min_scenario_tag_environment_repair_advice_count": 1,
    "min_scenario_tag_no_test_command_count": 1,
    "min_scenario_tag_runner_fallback_count": 1,
    "min_artifact_core_ready_count": 2,
    "min_artifact_required_ready_count": 2,
    "min_artifact_file_checked_count": 2,
    "min_acceptance_gate_pass_count": 2,
    "min_agent_goal_readiness_pass_count": 2,
    "min_objective_compliance_pass_count": 2,
    "max_objective_compliance_failed_section_kind_count": 0,
    "min_agent_controller_loop_complete_count": 2,
    "min_agent_decision_timeline_complete_count": 2,
    "min_agent_answer_coverage_complete_count": 2,
    "min_blocked_agent_answer_complete_count": 2,
    "max_blocked_agent_answer_incomplete_count": 0,
    "min_repository_structure_modeled_count": 2,
    "min_repo_graph_ready_count": 2,
    "min_program_graph_available_count": 2,
    "min_repository_test_environment_diagnosed_count": 2,
    "min_repository_test_setup_doctor_diagnosed_count": 2,
    "min_repository_test_recommended_install_command_count": 1,
    "min_planned_repository_test_runner_fallback_count": 1,
    "min_repository_test_execution_result_count": 2,
    "min_repository_test_counted_run_count": 1,
    "min_repository_test_count": 1,
    "min_repository_test_setup_doctor_blocker_environment_test_tool_missing_count": 1,
    "min_repository_test_setup_doctor_blocker_test_command_no_recommended_test_command_count": 1
  },
  "runs": [
    {
      "name": "pypa_sampleproject_repo_only_environment_blocker",
      "repo": "pypa/sampleproject",
      "prefer_cached_discovery": true,
      "seed_discovery_path": "datasets/github_cases/discovery_cache/pypa_sampleproject.discovery.json",
      "scenario_tags": [
        "cli_default_output",
        "owner_repo_input",
        "default_branch_discovery",
        "source_cache",
        "agent_auto",
        "checkout_tests",
        "runner_fallback",
        "test_environment_blocker",
        "environment_repair_advice",
        "regression_guard"
      ],
      "expected_status": "pass",
      "expected_agent_shortcut": true,
