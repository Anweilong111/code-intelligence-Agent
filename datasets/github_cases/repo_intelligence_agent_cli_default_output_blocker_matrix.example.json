      "repo": "https://github.com/karpathy/nanoGPT",
      "prefer_cached_discovery": true,
      "seed_discovery_path": "datasets/github_cases/discovery_cache/karpathy_nanogpt_master.discovery.json",
      "checkout_repository_tests": true,
      "repository_test_timeout": 8,
