{
  "suite_name": "repo_intelligence_smoke_suite",
  "description": "Example batch smoke suite for arbitrary public Python GitHub repo intelligence reports. It checks that each run writes auditable artifacts and exposes Agent Controller decisions.",
  "defaults": {
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 50,
    "max_candidates": 20,
    "auto_fallback": true,
    "run_repository_test_command": true,
    "checkout_repository_tests": false,
    "repository_patch_generation_mode": "rule",
    "repository_test_timeout": 20,
    "auto_controller_actions": false
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "min_artifact_core_ready_count": 3,
    "min_artifact_file_checked_count": 3,
    "min_agent_controller_loop_complete_count": 3,
    "min_agent_decision_timeline_complete_count": 3,
    "min_agent_answer_coverage_complete_count": 3,
    "min_agent_answer_testability_status_kind_count": 2,
    "min_agent_answer_repairability_status_kind_count": 2,
    "min_repository_structure_modeled_count": 2,
    "min_repo_graph_ready_count": 2,
    "min_program_graph_available_count": 2,
    "min_planned_repository_test_command_count": 2,
    "min_repository_test_environment_diagnosed_count": 2,
    "min_repository_test_setup_doctor_diagnosed_count": 2,
    "min_repository_test_recommended_install_command_count": 2,
    "min_phase2_static_graph_fault_localization_count": 2,
    "min_source_import_blocked_count": 1
  },
  "runs": [
    {
      "name": "thealgorithms_average_mean_static",
      "repo": "https://github.com/TheAlgorithms/Python",
      "ref": "6c0462028f547fc905a4d9a8cc956daed8a00cd8",
      "include": [
        "maths/average_mean.py"
      ],
      "recipes": [
        "missing_len_zero_guard"
      ],
      "expected_status": "pass",
      "expected_analysis_stage": "phase2_static_graph_fault_localization",
      "expected_controller_action": "run_repository_tests_with_checkout",
      "expected_artifact_inventory_status": "pass",
      "expected_patch_generation_mode": "rule",
      "expected_agent_answer_testability_status": "can_attempt_with_checkout_or_setup",
      "expected_agent_answer_repairability_status": "needs_dynamic_evidence_or_patch_context",
      "expected_repository_test_environment_status": "warning",
      "expected_repository_test_setup_doctor_status": "blocked",
      "expected_repository_test_setup_doctor_blocker": "checkout:full_repo_not_materialized",
      "metric_thresholds": {
        "artifact_inventory_core_file_nonempty_count": 18,
        "artifact_inventory_required_file_nonempty_count": 26,
        "repository_structure_analyzed_file_count": 1,
        "repository_structure_function_count": 1,
        "repository_structure_total_loc": 1,
        "repository_structure_call_site_count": 1,
        "repo_graph_file_node_count": 1,
        "repo_graph_function_node_count": 1,
        "repo_graph_program_graph_available": 1,
        "repo_graph_program_graph_node_count": 1,
        "repo_graph_program_graph_edge_count": 1,
        "repository_test_pytest_config_source_count": 1,
        "repository_test_ci_test_command_candidate_count": 1,
        "fault_localization_rankings_with_static_rule_score_count": 1,
        "fault_localization_rankings_with_graph_score_count": 1,
        "fault_localization_rankings_with_source_role_score_count": 1,
        "fault_localization_rankings_with_final_score_count": 1,
        "fault_localization_top_static_rule_score": 0.1,
        "fault_localization_top_graph_score": 0.1,
        "fault_localization_top_source_role_score": 0.1,
        "fault_localization_top_final_score": 0.1,
        "fault_localization_ranking_count": 1
      }
    },
    {
      "name": "pypa_sampleproject_static",
      "repo": "https://github.com/pypa/sampleproject",
      "expected_status": "pass",
      "expected_analysis_stage": "phase2_static_graph_fault_localization",
      "expected_artifact_inventory_status": "pass",
      "expected_patch_generation_mode": "rule",
      "expected_agent_answer_testability_status": "can_attempt_with_checkout_or_setup",
      "expected_agent_answer_repairability_status": "needs_dynamic_evidence_or_patch_context",
      "expected_repository_test_environment_status": "warning",
      "expected_repository_test_setup_doctor_status": "blocked",
      "expected_repository_test_setup_doctor_blocker": "checkout:full_repo_not_materialized",
      "metric_thresholds": {
        "artifact_inventory_core_file_nonempty_count": 18,
        "artifact_inventory_required_file_nonempty_count": 26,
        "repository_structure_analyzed_file_count": 1,
        "repository_structure_function_count": 1,
        "repository_structure_total_loc": 1,
        "repository_structure_call_site_count": 1,
        "repo_graph_file_node_count": 1,
        "repo_graph_function_node_count": 1,
        "repo_graph_program_graph_available": 1,
        "repo_graph_program_graph_node_count": 1,
        "repo_graph_program_graph_edge_count": 1,
        "repository_test_ci_install_command_candidate_count": 1,
        "repository_test_ci_test_command_candidate_count": 1,
        "fault_localization_rankings_with_static_rule_score_count": 1,
        "fault_localization_rankings_with_graph_score_count": 1,
        "fault_localization_rankings_with_source_role_score_count": 1,
        "fault_localization_rankings_with_final_score_count": 1,
        "fault_localization_top_static_rule_score": 0.1,
        "fault_localization_top_graph_score": 0.1,
        "fault_localization_top_source_role_score": 0.1,
        "fault_localization_top_final_score": 0.1
      }
    },
    {
      "name": "octocat_hello_world_no_python",
      "repo": "https://github.com/octocat/Hello-World",
      "auto_fallback": false,
      "expected_status": "pass",
      "expected_analysis_stage": "source_import_blocked",
      "expected_blocker": "source_import_or_parse_missing",
      "expected_controller_action": "adjust_source_filters",
      "expected_artifact_inventory_status": "pass",
      "expected_patch_generation_mode": "rule",
      "expected_agent_answer_testability_status": "blocked",
      "expected_agent_answer_repairability_status": "not_ready",
      "metric_thresholds": {
        "artifact_inventory_core_file_nonempty_count": 18,
        "artifact_inventory_required_file_nonempty_count": 26
      }
    }
  ]
}
