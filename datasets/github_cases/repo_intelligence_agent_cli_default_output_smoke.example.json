    "min_agent_default_output_dir_count": 1,
    "min_agent_controller_loop_complete_count": 1,
    "min_agent_decision_timeline_complete_count": 1,
    "min_agent_answer_coverage_complete_count": 1,
    "min_objective_compliance_pass_count": 1,
    "max_objective_compliance_failed_section_kind_count": 0,
    "min_static_analysis_ready_count": 1,
    "min_repository_test_dynamic_evidence_level_kind_count": 1,
    "min_repository_test_execution_result_count": 1,
    "min_repository_test_counted_run_count": 1,
    "min_repository_test_count": 1,
    "min_repository_test_passed_count": 1,
    "min_repository_test_count_source_kind_count": 1,
    "min_agent_auto_complete_loop_count": 1,
    "min_agent_auto_action_loop_complete_run_count": 1,
