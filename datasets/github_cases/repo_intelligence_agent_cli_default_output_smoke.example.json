{
  "suite_name": "repo_intelligence_agent_cli_default_output_smoke",
  "description": "Dedicated one-command smoke suite for the arbitrary-repo intelligence Agent default-output CLI path. It invokes github_repo_intelligence through the CLI parser without an output_dir positional argument by setting use_cli_default_output_dir=true. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_agent_cli_default_output_smoke.example.json outputs_smoke/repo_intelligence_agent_cli_default_output_current --require-success",
  "defaults": {
    "agent": true,
    "preset": "mining",
    "max_sources": 50,
    "max_candidates": 20,
    "auto_fallback": true,
    "run_repository_test_command": true,
    "repository_patch_generation_mode": "rule",
    "repository_test_timeout": 20,
    "repository_checkout_depth": 1,
    "auto_controller_max_actions": 4,
    "use_cli_default_output_dir": true
