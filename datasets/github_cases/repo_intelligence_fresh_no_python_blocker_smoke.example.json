{
  "suite_name": "repo_intelligence_fresh_no_python_blocker_smoke",
  "description": "Fresh no-Python/source-filter blocker smoke for the arbitrary public Python GitHub repository Agent. It validates that a GitHub URL run over a repository with no analyzable Python source still regenerates auditable artifacts, reports source_import_blocked, selects adjust_source_filters, and answers blocker plus next action without claiming repair. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_fresh_no_python_blocker_smoke.example.json outputs_smoke/repo_intelligence_fresh_no_python_blocker_smoke_current --format json --require-success",
  "defaults": {
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 30,
    "max_candidates": 10,
    "auto_fallback": false,
    "run_repository_test_command": false,
    "repository_patch_generation_mode": "rule",
    "repository_test_timeout": 20,
    "repository_checkout_timeout": 120,
    "repository_checkout_depth": 1,
    "auto_controller_max_actions": 2
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "max_existing_report_reuse_count": 0,
    "max_cached_report_fallback_count": 0,
    "max_discovery_cache_fallback_count": 0,
    "max_scenario_coverage_blocked_count": 0,
    "max_repository_test_execution_result_count": 0,
    "max_repository_structure_modeled_count": 0,
    "max_repo_graph_ready_count": 0,
    "max_program_graph_available_count": 0,
    "min_run_count": 1,
    "min_discovery_cache_reuse_count": 1,
    "min_repo_input_kind_github_url_count": 1,
    "min_scenario_tag_fresh_live_count": 1,
    "min_scenario_tag_github_url_input_count": 1,
    "min_scenario_tag_pinned_ref_count": 1,
    "min_scenario_tag_shallow_checkout_count": 1,
    "min_scenario_tag_no_python_blocker_count": 1,
    "min_scenario_tag_static_fallback_count": 1,
    "min_scenario_tag_test_execution_disabled_count": 1,
    "min_artifact_core_ready_count": 1,
    "min_artifact_required_ready_count": 1,
    "min_artifact_file_checked_count": 1,
    "min_acceptance_gate_pass_count": 1,
    "min_agent_goal_readiness_pass_count": 1,
    "min_objective_compliance_pass_count": 1,
    "max_objective_compliance_failed_section_kind_count": 0,
    "min_agent_controller_loop_complete_count": 1,
    "min_agent_decision_timeline_complete_count": 1,
    "min_agent_answer_coverage_complete_count": 1,
    "min_blocked_agent_answer_complete_count": 1,
    "max_blocked_agent_answer_incomplete_count": 0,
    "min_source_import_blocked_count": 1
  },
  "runs": [
    {
      "name": "octocat_hello_world_fresh_no_python_blocker",
      "repo": "https://github.com/octocat/Hello-World",
      "ref": "master",
      "execution_profile": "checkout",
      "prefer_cached_discovery": true,
      "seed_discovery_path": "datasets/github_cases/discovery_cache/octocat_hello_world_master.discovery.json",
      "run_repository_test_command": false,
      "auto_fallback": false,
      "scenario_tags": [
        "fresh_live",
        "github_url_input",
        "pinned_ref",
        "shallow_checkout",
        "no_python_blocker",
        "static_fallback",
        "test_execution_disabled"
      ],
      "expected_status": "pass",
      "expected_execution_profile": "checkout",
      "expected_analysis_stage": "source_import_blocked",
      "expected_blocker": "source_import_or_parse_missing",
      "expected_controller_action": "adjust_source_filters",
      "expected_artifact_inventory_status": "pass",
      "expected_dynamic_evidence_level": "none",
      "expected_agent_answer_testability_status": "not_available",
      "expected_agent_answer_repairability_status": "not_ready",
      "metric_thresholds": {
        "artifact_inventory_core_file_nonempty_count": 18,
        "artifact_inventory_required_file_nonempty_count": 20,
        "discovery_cache_reuse": 1,
        "discovery_cache_preferred": 1,
        "agent_controller_loop_complete": 1,
        "agent_decision_timeline_complete": 1,
        "agent_answer_coverage_answered_count": 7,
        "acceptance_gate_repair_decision_audit_passed": 1,
        "agent_goal_repair_decision_audit_passed": 1,
        "objective_compliance_passed": 1
      }
    }
  ]
}
