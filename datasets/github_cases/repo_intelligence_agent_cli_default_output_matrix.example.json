{
  "suite_name": "repo_intelligence_agent_cli_default_output_matrix",
  "description": "Small repo-only CLI default-output Agent matrix for arbitrary public repository handling. Every run uses agent=true and use_cli_default_output_dir=true, so the suite invokes github_repo_intelligence without an explicit output_dir positional argument and verifies the generated outputs/repo_intelligence_agent_<owner>_<repo> report. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_agent_cli_default_output_matrix.example.json outputs_smoke/repo_intelligence_agent_cli_default_output_matrix_current --require-success",
  "defaults": {
    "agent": true,
    "preset": "mining",
    "max_sources": 30,
    "max_candidates": 10,
    "auto_fallback": true,
    "run_repository_test_command": true,
    "repository_patch_generation_mode": "rule",
    "repository_test_timeout": 20,
    "repository_checkout_depth": 1,
    "auto_controller_max_actions": 4,
    "use_cli_default_output_dir": true
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "max_scenario_coverage_blocked_count": 0,
    "min_run_count": 3,
    "min_repo_input_kind_count": 2,
    "min_repo_input_kind_owner_repo_count": 1,
    "min_repo_input_kind_github_url_count": 2,
    "min_scenario_tag_kind_count": 10,
    "min_scenario_tag_cli_default_output_count": 3,
    "min_scenario_tag_owner_repo_input_count": 1,
    "min_scenario_tag_github_url_input_count": 2,
    "min_scenario_tag_default_branch_discovery_count": 1,
    "min_scenario_tag_pinned_ref_count": 2,
    "min_scenario_tag_include_filter_count": 1,
    "min_scenario_tag_src_layout_count": 1,
    "min_scenario_tag_no_python_blocker_count": 1,
    "min_scenario_tag_static_fallback_count": 2,
    "min_scenario_tag_test_execution_disabled_count": 1,
    "min_scenario_tag_passing_tests_dynamic_evidence_count": 2,
    "min_artifact_core_ready_count": 3,
    "min_artifact_file_checked_count": 3,
    "min_agent_shortcut_count": 3,
    "min_output_dir_defaulted_count": 3,
    "min_agent_default_output_dir_count": 3,
    "min_agent_controller_loop_complete_count": 3,
    "min_agent_decision_timeline_complete_count": 3,
    "min_agent_answer_coverage_complete_count": 3,
    "min_blocked_agent_answer_complete_count": 3,
    "max_blocked_agent_answer_incomplete_count": 0,
    "min_objective_compliance_pass_count": 3,
    "max_objective_compliance_failed_section_kind_count": 0,
    "min_repository_structure_modeled_count": 2,
    "min_repository_structure_src_layout_detected_count": 1,
    "min_repo_graph_ready_count": 2,
    "min_program_graph_available_count": 2,
    "min_source_import_blocked_count": 1,
    "min_repository_test_execution_result_count": 2,
    "min_repository_test_counted_run_count": 2,
    "min_repository_test_count": 1,
    "min_repository_test_count_source_kind_count": 2
  },
  "runs": [
    {
      "name": "pypa_sampleproject_repo_only_default_output",
      "repo": "pypa/sampleproject",
      "prefer_cached_discovery": true,
      "seed_discovery_path": "datasets/github_cases/discovery_cache/pypa_sampleproject.discovery.json",
      "scenario_tags": [
        "cli_default_output",
        "owner_repo_input",
        "default_branch_discovery",
        "agent_auto",
        "nox_project",
        "unittest_fallback",
        "passing_tests_dynamic_evidence"
      ],
      "expected_status": "pass",
      "expected_agent_shortcut": true,
      "expected_execution_profile": "agent-auto",
      "expected_artifact_inventory_status": "pass",
      "expected_patch_generation_mode": "rule",
      "expected_llm_patch_generation_status": "disabled",
      "expected_planned_repository_test_result_status": "pass",
      "metric_thresholds": {
        "output_dir_defaulted": 1,
        "artifact_inventory_core_file_nonempty_count": 18,
        "agent_controller_loop_complete": 1,
        "agent_decision_timeline_complete": 1,
        "agent_answer_coverage_answered_count": 7,
        "planned_repository_test_result_test_count": 1,
        "planned_repository_test_result_passed": 1,
        "objective_compliance_passed": 1
      }
    },
    {
      "name": "pluggy_src_layout_repo_only_default_output",
      "repo": "https://github.com/pytest-dev/pluggy",
      "ref": "7fce99cb955846901b22b051909aa4f30dc16128",
      "prefer_cached_discovery": true,
      "seed_discovery_path": "datasets/github_cases/discovery_cache/pytest_dev_pluggy_7fce99c.discovery.json",
      "run_repository_test_command": false,
      "include": [
        "src/pluggy/__init__.py",
        "src/pluggy/_tracing.py"
      ],
      "scenario_tags": [
        "cli_default_output",
        "github_url_input",
        "pinned_ref",
        "include_filter",
        "src_layout",
        "pytest_project",
        "static_fallback",
        "passing_tests_dynamic_evidence"
      ],
      "expected_status": "pass",
      "expected_agent_shortcut": true,
      "expected_execution_profile": "agent-auto",
      "expected_analysis_stage": "phase2_static_graph_fault_localization",
      "expected_blocker": "dynamic_evidence_not_usable:passing_tests",
      "expected_controller_action": "extend_failure_overlay_or_provide_bug_report",
      "expected_artifact_inventory_status": "pass",
      "expected_dynamic_evidence_level": "passing_tests",
      "expected_agent_answer_testability_status": "overlay_not_usable",
      "expected_agent_answer_repairability_status": "needs_dynamic_evidence_or_patch_context",
      "expected_planned_repository_test_result_status": "pass",
      "metric_thresholds": {
        "output_dir_defaulted": 1,
        "artifact_inventory_core_file_nonempty_count": 18,
        "repository_structure_analyzed_file_count": 2,
        "repository_structure_src_layout_package_count": 1,
        "repo_graph_program_graph_available": 1,
        "fault_localization_ranking_count": 1,
        "agent_controller_loop_complete": 1,
        "agent_decision_timeline_complete": 1,
        "agent_answer_coverage_answered_count": 7,
        "planned_repository_test_result_test_count": 1,
        "planned_repository_test_result_passed": 1,
        "objective_compliance_passed": 1
      }
    },
    {
      "name": "octocat_no_python_repo_only_default_output",
      "repo": "https://github.com/octocat/Hello-World",
      "ref": "master",
      "prefer_cached_discovery": true,
      "seed_discovery_path": "datasets/github_cases/discovery_cache/octocat_hello_world_master.discovery.json",
      "run_repository_test_command": false,
      "auto_fallback": false,
      "scenario_tags": [
        "cli_default_output",
        "github_url_input",
        "pinned_ref",
        "no_python_blocker",
        "static_fallback",
        "test_execution_disabled"
      ],
      "expected_status": "pass",
      "expected_agent_shortcut": true,
      "expected_execution_profile": "agent-auto",
      "expected_analysis_stage": "source_import_blocked",
      "expected_blocker": "source_import_or_parse_missing",
      "expected_controller_action": "adjust_source_filters",
      "expected_artifact_inventory_status": "pass",
      "expected_dynamic_evidence_level": "none",
      "expected_agent_answer_testability_status": "not_available",
      "expected_agent_answer_repairability_status": "not_ready",
      "metric_thresholds": {
        "output_dir_defaulted": 1,
        "artifact_inventory_core_file_nonempty_count": 18,
        "agent_controller_loop_complete": 1,
        "agent_decision_timeline_complete": 1,
        "agent_answer_coverage_answered_count": 7,
        "objective_compliance_passed": 1
      }
    }
  ]
}
