{
  "suite_name": "repo_intelligence_hybrid_no_key_smoke",
  "description": "Example one-command hybrid patch-generation smoke suite that clears LLM API key env vars for the run. It verifies that hybrid mode records the LLM blocker without leaking secrets or claiming LLM repair, while rule candidates still pass safety gates and sandbox validation.",
  "defaults": {
    "execution_profile": "phase3-fast",
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 50,
    "max_candidates": 20,
    "auto_fallback": true,
    "clear_llm_api_keys": true,
    "repository_test_timeout": 3,
    "repository_checkout_depth": 1,
    "repository_test_failure_overlay_candidate_limit": 6,
    "repository_patch_generation_mode": "hybrid",
    "repository_llm_patch_candidate_limit": 1,
    "repository_test_reflection_mode": "rule",
    "repository_test_reflection_rounds": 1,
    "repository_test_reflection_width": 1
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "min_artifact_core_ready_count": 1,
    "min_artifact_file_checked_count": 1,
    "min_agent_controller_loop_complete_count": 1,
    "min_agent_decision_timeline_complete_count": 1,
    "min_agent_answer_coverage_complete_count": 1,
    "min_repository_test_failure_overlay_ready_count": 1,
    "min_repository_test_patch_candidates_ready_count": 1,
    "min_repository_test_patch_validation_ready_count": 1,
    "min_repository_test_patch_validation_success_count": 1,
    "min_repository_test_repair_ready_count": 1,
    "min_repository_patch_generator_rule_candidate_count": 1
  },
  "runs": [
    {
      "name": "thealgorithms_gronsfeld_hybrid_no_key",
      "repo": "https://github.com/TheAlgorithms/Python",
      "ref": "6c0462028f547fc905a4d9a8cc956daed8a00cd8",
      "include": [
        "ciphers/gronsfeld_cipher.py"
      ],
      "expected_status": "pass",
      "expected_execution_profile": "phase3-fast",
      "expected_failure_overlay_status": "pass",
      "expected_patch_candidates_status": "pass",
      "expected_patch_generation_mode": "hybrid",
      "expected_llm_patch_generation_status": "blocked",
      "expected_patch_safety_gate_status": "pass",
      "expected_patch_validation_status": "pass",
      "expected_repair_validation_scope": "narrow_and_unchanged_regression_baseline",
      "metric_thresholds": {
        "artifact_inventory_core_file_nonempty_count": 18,
        "artifact_inventory_required_file_nonempty_count": 34,
        "repository_test_patch_validation_success_count": 1,
        "repository_test_patch_candidate_count": 1,
        "repository_patch_generator_rule_count": 1
      }
    }
  ]
}
