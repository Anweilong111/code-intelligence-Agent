{
  "suite_name": "repo_intelligence_agent_cli_default_output_repair_smoke",
  "description": "Repo-only CLI default-output repair smoke for the arbitrary-repo intelligence Agent. It starts through --agent without an output_dir positional argument, lets AgentController choose checkout/test/repair actions, and gates that patch validation plus rule reflection succeed from the generated outputs/repo_intelligence_agent_<owner>_<repo> report. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_agent_cli_default_output_repair_smoke.example.json outputs_smoke/repo_intelligence_agent_cli_default_output_repair_current --require-success",
  "defaults": {
    "agent": true,
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 50,
    "max_candidates": 20,
    "auto_fallback": false,
    "run_repository_test_command": true,
    "repository_test_timeout": 3,
    "repository_checkout_depth": 1,
    "repository_test_failure_overlay_candidate_limit": 5,
    "repository_patch_generation_mode": "rule",
    "repository_patch_candidate_variant_allowlist": [
      "insert_len_zero_guard"
    ],
    "repository_test_reflection_mode": "rule",
    "repository_test_reflection_rounds": 1,
    "repository_test_reflection_width": 1,
    "auto_controller_max_actions": 4,
    "use_cli_default_output_dir": true
  },
  "suite_thresholds": {
