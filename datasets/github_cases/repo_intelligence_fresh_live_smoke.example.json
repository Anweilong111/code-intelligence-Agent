    "min_scenario_tag_checkout_tests_count": 1,
    "min_scenario_tag_runner_fallback_count": 1,
    "min_scenario_tag_regression_guard_count": 1,
    "min_artifact_core_ready_count": 1,
    "min_artifact_required_ready_count": 1,
    "min_artifact_file_checked_count": 1,
