{
  "suite_name": "repo_intelligence_fresh_live_smoke",
  "description": "Fresh end-to-end live smoke for the arbitrary public Python GitHub repository Agent. It intentionally forbids existing-report reuse so the run must regenerate the repository intelligence report, controller decision report, test diagnosis, dynamic-test result, blocker explanation, and next action from a public GitHub repo input. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_fresh_live_smoke.example.json outputs_smoke/repo_intelligence_fresh_live_smoke_current --format json --require-success",
  "defaults": {
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 30,
    "max_candidates": 10,
    "auto_fallback": true,
    "run_repository_test_command": true,
    "repository_patch_generation_mode": "rule",
    "repository_test_timeout": 20,
    "repository_checkout_timeout": 120,
    "repository_checkout_depth": 1,
    "auto_controller_max_actions": 2
  },
  "suite_thresholds": {
