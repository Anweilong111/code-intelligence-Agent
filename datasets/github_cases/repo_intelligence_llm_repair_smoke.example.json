{
  "suite_name": "repo_intelligence_llm_repair_smoke",
  "description": "Example one-command real LLM auto-repair smoke suite for a public Python GitHub repository. This suite is intentionally strict: it requires CIA_LLM_API_KEY or DEEPSEEK_API_KEY for patch/reflection and CIA_JUDGE_API_KEY or DEEPSEEK_API_KEY for patch judging to be present outside the repository, uses llm-only patch generation plus llm patch judge, and only passes when an LLM-generated candidate survives AST/scope safety checks and sandbox patch validation. Do not store API keys in this manifest.",
  "defaults": {
    "execution_profile": "phase3-fast",
    "preset": "mining",
    "source_cache_dir": "outputs_smoke/github_raw_source_cache",
    "max_sources": 50,
    "max_candidates": 20,
    "auto_fallback": true,
    "clear_llm_api_keys": false,
    "require_llm_configuration": true,
    "reject_placeholder_llm_api_keys": true,
    "llm_api_key_min_length": 20,
    "run_llm_repair_showcase_matrix": true,
    "run_repository_test_command": true,
    "repository_test_timeout": 3,
    "repository_checkout_depth": 1,
    "repository_test_failure_overlay_candidate_limit": 6,
    "repository_patch_generation_mode": "llm",
    "repository_llm_patch_candidate_limit": 2,
    "repository_test_reflection_mode": "llm",
    "repository_test_reflection_rounds": 1,
    "repository_test_reflection_width": 2,
    "patch_judge_mode": "llm"
  },
  "suite_thresholds": {
    "max_command_failed_count": 0,
    "max_expectation_failed_count": 0,
    "max_metric_check_failed_count": 0,
    "max_existing_report_reuse_count": 0,
    "max_cached_report_fallback_count": 0,
    "min_artifact_core_ready_count": 1,
    "min_artifact_required_ready_count": 1,
    "min_artifact_file_checked_count": 1,
    "min_agent_controller_loop_complete_count": 1,
    "min_agent_decision_timeline_complete_count": 1,
    "min_agent_answer_coverage_complete_count": 1,
    "min_repository_test_failure_overlay_ready_count": 1,
    "min_repository_test_patch_candidates_ready_count": 1,
    "min_repository_test_patch_validation_ready_count": 1,
    "min_repository_test_patch_validation_success_count": 1,
    "min_repository_test_repair_ready_count": 1,
    "min_repository_patch_generator_llm_candidate_count": 1,
    "min_repository_test_patch_judge_candidate_count": 1
  },
  "runs": [
    {
      "name": "thealgorithms_gronsfeld_llm_repair",
      "repo": "https://github.com/TheAlgorithms/Python",
      "ref": "6c0462028f547fc905a4d9a8cc956daed8a00cd8",
      "include": [
        "ciphers/gronsfeld_cipher.py"
      ],
      "scenario_tags": [
        "p5_llm_auto_repair",
        "real_llm_required",
        "deepseek_env_required",
        "llm_patch_generation",
        "llm_reflection",
        "sandbox_patch_validation"
      ],
      "expected_status": "pass",
      "expected_execution_profile": "phase3-fast",
      "expected_failure_overlay_status": "pass",
      "expected_patch_candidates_status": "pass",
      "expected_patch_generation_mode": "llm",
      "expected_llm_patch_generation_status": "pass",
      "expected_patch_safety_gate_status": "pass",
      "expected_patch_validation_status": "pass",
      "expected_patch_judge_mode": "llm",
      "expected_patch_judge_status": "ready",
      "expected_repair_validation_scope": "narrow_and_unchanged_regression_baseline",
      "metric_thresholds": {
        "artifact_inventory_core_file_nonempty_count": 18,
        "artifact_inventory_required_file_nonempty_count": 34,
        "repository_patch_generator_llm_count": 1,
        "repository_test_patch_judge_candidate_count": 1,
        "repository_test_patch_candidate_count": 1,
        "repository_test_patch_validation_success_count": 1
      }
    }
  ]
}
