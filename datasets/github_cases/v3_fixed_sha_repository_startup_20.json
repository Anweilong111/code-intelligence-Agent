{
  "suite_name": "v3_fixed_sha_repository_startup_20",
  "description": "V3 paired repository-startup experiment over the same 20 fixed commits used by the V2 unfamiliar-repository cohort. All cases explicitly authorize checkout and a bounded isolated pytest runner probe; project dependency installation remains disabled.",
  "protocol": {
    "selected_at": "2026-07-15",
    "role": "paired_v2_v3_startup_comparison",
    "paired_manifest": "datasets/github_cases/v2_unfamiliar_python_repositories_20.json",
    "fixed_commit_required": true,
    "case_count": 20,
    "execution_authorization_change": "V2 authorized checkout for 7/20 cases; V3 authorizes a bounded checkout probe for 20/20 cases.",
    "success_boundary": "A started and terminated pytest process is startup evidence only. It is not a passing test suite, a repaired defect, or full-regression evidence.",
    "safety_boundary": "The setup step creates an isolated venv and installs only pytest. It does not install the repository, requirements, extras, tox, nox, or project build hooks.",
    "network_policy": "Network is used for fixed-SHA checkout and pytest package resolution only; repository tests run with the existing subprocess network policy.",
    "comparison_warning": "V2 and V3 startup rates use different execution authorization and setup protocols. Report the protocol change next to every rate comparison."
