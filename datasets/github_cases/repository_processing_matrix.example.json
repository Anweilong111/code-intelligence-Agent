{
  "suite_name": "github_repository_processing_matrix_example",
  "description": "Pinned multi-repository pipeline example for validating repository_processing_matrix across repaired, checkout-tested and dependency-sensitive GitHub repositories.",
  "defaults": {
    "mode": "repo",
    "preset": "smoke",
    "sample_sources": 20,
    "max_candidates": 5,
    "checkout_repository_tests": true,
    "repository_checkout_depth": 1,
    "repository_test_timeout": 20,
    "repository_test_failure_overlay_candidate_limit": 8,
    "auto_repository_test_retry": true,
    "auto_repository_test_retry_max_risk": "low",
    "auto_repository_test_retry_allowed_runners": [
      "pytest",
      "unittest"
    ],
    "auto_scoped_include": true,
    "fallback": {
      "enabled": true,
      "max_sources": 50,
      "max_candidates": 20
    }
  },
  "promotion_gate": {
    "min_smoke_benchmark_cases": 0,
    "min_repository_test_phase2_ready_count": 1,
    "min_repository_test_phase3_validation_ready_count": 1,
    "min_repository_test_repaired_count": 1,
    "allow_warning_stages": true
  },
  "repository_processing_matrix_expectations": {
    "min_run_count": 3,
    "min_primary_layer_counts": {
      "repository_repair": 1
    },
    "min_repair_summary_status_counts": {
      "pass": 1
    },
    "min_repair_summary_conclusion_counts": {
      "ready_for_review": 1
    },
    "run_expectations": {
      "thealgorithms_gronsfeld_matrix": {
        "allowed_statuses": [
          "repaired",
          "phase3_ready",
          "phase2_ready"
        ],
        "allowed_primary_layers": [
          "repository_repair",
          "fault_localization"
        ],
        "allowed_primary_blockers": [
          "none",
          "patch_generation_not_executed"
        ],
        "allowed_repair_summary_statuses": [
          "pass",
          "warning"
        ],
        "allowed_repair_summary_conclusions": [
          "ready_for_review",
          "not_ready"
        ],
        "repair_summary_path_contains": "repository_test_repair_summary.md",
        "purpose": "Small algorithm repository slice expected to exercise failure-overlay repair or at least Phase 2/3 readiness."
      },
      "pluggy_tracing_matrix": {
        "allowed_statuses": [
          "repaired",
          "phase3_ready",
          "phase2_ready",
          "blocked"
        ],
        "allowed_primary_layers": [
          "repository_repair",
          "fault_localization",
          "repository_test_execution"
        ],
        "allowed_primary_blockers": [
          "none",
          "repository_tests_passing",
          "patch_generation_not_executed"
        ],
        "allowed_primary_blocker_prefixes": [
          "dynamic_evidence_not_usable:"
        ],
        "allowed_repair_summary_statuses": [
          "pass",
          "warning",
          "skipped"
        ],
        "allowed_repair_summary_conclusions": [
          "ready_for_review",
          "not_ready"
        ],
        "purpose": "Src-layout package checkout expected to validate real pytest planning and distinguish passing tests from repair-ready evidence."
      },
      "requests_models_matrix": {
        "allowed_statuses": [
          "repaired",
          "phase3_ready",
          "phase2_ready",
          "blocked",
          "incomplete"
        ],
        "allowed_primary_layers": [
          "repository_repair",
          "fault_localization",
          "repository_test_setup",
          "repository_test_execution"
        ],
        "allowed_primary_blockers": [
          "none",
          "patch_generation_not_executed",
          "repository_test_not_executed"
        ],
        "allowed_primary_blocker_prefixes": [
          "setup_install_failure:",
          "dynamic_evidence_not_usable:",
          "execution_status:"
        ],
        "allowed_repair_summary_statuses": [
          "pass",
          "warning",
          "skipped"
        ],
        "allowed_repair_summary_conclusions": [
          "ready_for_review",
          "not_ready"
        ],
        "purpose": "Dependency-sensitive package slice expected to exercise setup/execution diagnostics if full repair evidence is not available."
      }
    }
  },
  "runs": [
    {
      "name": "thealgorithms_gronsfeld_matrix",
      "repo": "https://github.com/TheAlgorithms/Python",
      "ref": "6c0462028f547fc905a4d9a8cc956daed8a00cd8",
      "include": [
        "ciphers/gronsfeld_cipher.py"
      ],
      "sample_sources": 5,
      "repository_test_timeout": 3,
      "repository_test_failure_overlay_candidate_limit": 5,
      "expected_repository_processing": {
        "target_status": "repaired",
        "target_primary_layer": "repository_repair"
      }
    },
    {
      "name": "pluggy_tracing_matrix",
      "repo": "https://github.com/pytest-dev/pluggy",
      "ref": "7fce99cb955846901b22b051909aa4f30dc16128",
      "include": [
        "src/pluggy/_tracing.py"
      ],
      "expected_repository_processing": {
        "target_status": "repaired_or_blocked_with_dynamic_evidence_diagnosis",
        "target_primary_layers": [
          "repository_repair",
          "repository_test_execution"
        ]
      }
    },
    {
      "name": "requests_models_matrix",
      "repo": "https://github.com/psf/requests",
      "ref": "v2.31.0",
      "include": [
        "requests/models.py"
      ],
      "target_prefix": "requests",
      "sample_sources": 10,
      "run_repository_test_environment_setup": true,
      "repository_test_environment_setup_timeout": 45,
      "run_repository_test_retry_prerequisites": true,
      "expected_repository_processing": {
        "target_status": "setup_or_execution_diagnosed",
        "target_primary_layers": [
          "repository_test_setup",
          "repository_test_execution",
          "repository_repair"
        ]
      }
    }
  ]
}
