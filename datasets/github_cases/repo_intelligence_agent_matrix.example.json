{
  "suite_name": "repo_intelligence_agent_matrix",
  "description": "Multi-repository Agent matrix for validating arbitrary public Python GitHub repository intelligence across input forms, repository layouts, test runners, blockers, and repair readiness. Run with: python -m code_intelligence_agent.evaluation.github_repo_intelligence_suite datasets/github_cases/repo_intelligence_agent_matrix.example.json outputs_smoke/repo_intelligence_agent_matrix --require-success",
