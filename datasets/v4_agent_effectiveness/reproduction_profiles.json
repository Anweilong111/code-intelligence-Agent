        {
          "path": ".cia-runtime-support/cia_legacy_pytest.py",
          "content": "\"\"\"Compatibility for The Fuck's 2016 tests under pytest 3.10.1.\"\"\"\n\nimport os\n\nimport pytest\n\n\ndef pytest_configure(config):\n    del config\n    if pytest.__version__ != \"3.10.1\":\n        raise RuntimeError(\"legacy pytest adapter requires pytest==3.10.1\")\n    from _pytest import runner\n\n    if not hasattr(runner, \"_update_current_test_var\"):\n        raise RuntimeError(\"pytest current-test hook is unavailable\")\n\n    def clear_current_test(_item, _when):\n        os.environ.pop(\"PYTEST_CURRENT_TEST\", None)\n\n    runner._update_current_test_var = clear_current_test\n",
          "sha256": "6676f3717bfd738abfae0c2ff49b837546b16fb26f65b57138dc91b2ebe6915b",
          "reason": "Restore the 2016 test suite's pre-PYTEST_CURRENT_TEST environment semantics while retaining the benchmark-pinned pytest 3.10.1 runner.",
          "source_path": "tests/test_types.py",
          "source_text_sha256": "1470a42043a04e7769503350a5d5327c1fcc6b716a24d9bf5077f0fc355077c4"
        },
        {
